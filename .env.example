# OraFlow local development configuration.
# The VS Code extension sets bundled runtime paths automatically; future users
# should not need a .env file or any machine-level Oracle install.

# Optional explicit TNS files for local source-tree development. If omitted,
# OraFlow uses repo/bundled oracle-network\admin files.
# ORAFLOW_TNSNAMES_PATHS=oracle-network\admin\tnsnames.ora;oracle-network\admin\cloud-tnsnames.ora

# Optional explicit TNS admin directory for local source-tree development.
# ORAFLOW_TNS_ADMIN=oracle-network\admin

# Extension runtime sets these to bundled paths. Keep unset for normal local dev
# unless you are testing the packaged thick-mode runtime intentionally.
# ORAFLOW_THICK_MODE=true
# ORAFLOW_ORACLE_CLIENT_LIB_DIR=extensions\vscode\bin\win32-x64\instantclient

# Query defaults.
ORAFLOW_DEFAULT_MAX_ROWS=100
ORAFLOW_HARD_MAX_ROWS=1000
ORAFLOW_CONNECT_TIMEOUT_S=10
ORAFLOW_QUERY_TIMEOUT_S=30
# Rewrite descriptor HOST names to IPs with dnspython when Python socket DNS cannot resolve split-DNS hostnames.
ORAFLOW_RESOLVE_HOSTS=true

# Optional credential-profile file. The extension writes the default file at
# ~/.oraflow/credentials.toml.
# ORAFLOW_CREDENTIALS_PATH=%USERPROFILE%\.oraflow\credentials.toml
# ORAFLOW_DB_PROFILE=DEV-CLOUD

# Optional CLI convenience credentials. Prefer prompt input for password.
# ORAFLOW_DB_USER=
# ORAFLOW_DB_PASSWORD=
