# --- Python / tooling caches ---
.venv/
.pytest_cache/
.ruff_cache/
__pycache__/
**/__pycache__/
*.pyc

# --- IDE / editor ---
.idea/
.vscode/

# --- Local secrets / runtime outputs ---
.env
dbcreds.env
# Workspace evidence/state generated by OraFlow tools. This includes current
# db/jira evidence plus older pre-0.1.1 output layouts.
OraFlow/
context/lemedtest_results.txt
context/lemedtest_results_packaged.txt
# (legacy locations, kept so older clones still ignore them)
lemedtest_results.txt
lemedtest_results_packaged.txt

# Raw schema dumps generated by the manual TREXONE extract scripts.
trexone_data_dumps/*.sql

# --- PyInstaller build artifacts (oraflow-mcp.spec) ---
build/
dist/

# --- VS Code extension build artifacts ---
extensions/vscode/node_modules/
extensions/vscode/dist/
extensions/vscode/build/
extensions/vscode/oraflow-mcp/
extensions/vscode/bin/oraflow-mcp/
extensions/vscode/bin/
*.vsix

# --- Oracle Net generated runtime output; keep oracle-network/admin config files ---
oracle-network/log/*
oracle-network/trace/*
!oracle-network/log/.gitkeep
!oracle-network/trace/.gitkeep
